rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Strict rules for the "users" collection
    match /users/{userId} {
      // Anyone logged in can read profile data, only the owner can write
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Strict rules for the "libraries" collection
    match /libraries/{libraryId} {
      // Anyone logged in can read library items
      allow read: if request.auth != null;
      
      // Users can only delete a library item if it exists and belongs to them
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // Users can only create or update a library item if the data's userId matches their authenticated UID
      allow create, update: if request.auth != null 
        && request.resource.data.userId == request.auth.uid
        && (resource == null || resource.data.userId == request.auth.uid);
    }

    // Strict rules for the "comments" collection
    match /comments/{commentId} {
      // Anyone can view comments
      allow read: if true;

      // Users can delete their own comments
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;

      // Users can only update likesCount and dislikesCount fields on comments (e.g. reacting)
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'dislikesCount']);

      // Create rules:
      // - Must be logged in and writing their own userId
      // - Comment creation timestamp must match the request time
      // - Must update user profile lastCommentedAt to current request time in the same batch (via getAfter)
      // - Previous lastCommentedAt must be null or at least 5 minutes ago
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.createdAt == request.time
        && getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.lastCommentedAt == request.time
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('lastCommentedAt', null) == null
          || request.time >= get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('lastCommentedAt', null) + duration.value(5, 'm')
        );
    }

    // Strict rules for the "comment_reactions" collection
    match /comment_reactions/{reactionId} {
      // Users can only read their own reaction documents
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;

      // Users can only create or update their own reactions
      allow create, update: if request.auth != null 
        && request.resource.data.userId == request.auth.uid
        && (resource == null || resource.data.userId == request.auth.uid);

      // Users can delete their own reactions
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Strict rules for the "notifications" collection
    match /notifications/{notificationId} {
      // User can only read their own notifications
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // Anyone logged in can create a notification (to allow sending replies or writing library updates)
      allow create: if request.auth != null;
      
      // User can update/delete their own notifications (e.g. mark as read or dismiss)
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Strict rules for the "watch_history" collection
    match /watch_history/{historyId} {
      // Anyone logged in can read watch history items
      allow read: if request.auth != null;
      
      // Users can only delete a history item if it exists and belongs to them
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // Users can only create or update a history item if the data's userId matches their authenticated UID
      allow create, update: if request.auth != null 
        && request.resource.data.userId == request.auth.uid
        && (resource == null || resource.data.userId == request.auth.uid);
    }
  }
}
