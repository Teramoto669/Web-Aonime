rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Strict rules for the "users" collection
    match /users/{userId} {
      // Users can only read and write their own profile data
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Strict rules for the "libraries" collection
    match /libraries/{libraryId} {
      // Users can only read a library item if it belongs to them or if it doesn't exist yet (returns exists = false)
      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      
      // Users can only delete a library item if it exists and belongs to them
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // Users can only create or update a library item if the data's userId matches their authenticated UID
      allow create, update: if request.auth != null 
        && request.resource.data.userId == request.auth.uid
        && (resource == null || resource.data.userId == request.auth.uid);
    }
  }
}
